#!/bin/sh

PREREQ=""

prereqs()
{
	echo "${PREREQ}"
}

case "${1}" in
prereqs)
	prereqs
	exit 0
	;;
esac

. /usr/share/initramfs-tools/hook-functions

mkdir -p ${DESTDIR}/etc/moocbt/mnt
copy_exec /sbin/blkid
copy_exec /sbin/blockdev
copy_exec /usr/bin/moo
copy_exec /var/lib/moocbt/reload /sbin/moo_reload

manual_add_modules moocbt

exit 0

